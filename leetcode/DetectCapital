class Solution {
    public boolean detectCapitalUse(String word) {
        int len=word.length();
        int capitalCount=0;
        for(int i=0;i<word.length();i++){
            if(Character.isUpperCase(word.charAt(i))){
                capitalCount++;
            }
        }
        if(capitalCount==len || capitalCount==0){
            return true;
        }
        if(Character.isUpperCase(word.charAt(0)) && Character.isLowerCase(word.charAt(len-1)) && capitalCount==1){
            return true;
        }
        return false;
    }
}
